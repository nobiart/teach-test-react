{
  "compilerOptions": {
    "types": ["node"],
    "outDir": "./dist/",
    "rootDir": ".",
    "noImplicitAny": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "jsx": "react-jsx",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*", "webpack.config.ts"],
  "exclude": ["node_modules"]
}